# Copy to .env.local and fill in real values.

# --- Supabase (admin console) ---
# From Project Settings -> API
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# --- Gemini Flash (public concierge widget) ---
# Free tier key from https://aistudio.google.com
# Server-side only — must NOT be prefixed with VITE_ (would expose to browser).
GEMINI_API_KEY=YOUR_GEMINI_API_KEY
# Optional: override the default Gemini model.
# GEMINI_MODEL=gemini-2.5-flash
